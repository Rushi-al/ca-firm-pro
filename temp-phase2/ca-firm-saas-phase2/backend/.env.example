PORT=5000
MONGO_URI=mongodb://localhost:27017/ca-firm-saas
JWT_SECRET=change_this_to_a_very_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ADMIN_SECRET=your_internal_admin_secret

# Razorpay (get from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="CA Firm Pro <noreply@cafirmpro.com>"

# Plans (in paise — 1 rupee = 100 paise)
PLAN_PRO_MONTHLY=99900
PLAN_PRO_YEARLY=999900
PLAN_ENTERPRISE_MONTHLY=299900
PLAN_ENTERPRISE_YEARLY=2999900
